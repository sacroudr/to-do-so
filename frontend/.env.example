# =====================================================================
# Frontend (Next.js) — variables d'environnement
# Copiez ce fichier vers .env.local en local ; en production (Vercel),
# renseignez ces memes cles dans Project Settings > Environment Variables.
# .env.local est ignore par git. Les noms doivent correspondre a lib/env.ts.
#
# ATTENTION : les variables NEXT_PUBLIC_* sont INLINEES au moment du BUILD.
# Elles doivent donc etre definies AVANT le build ; toute modification exige
# un nouveau deploiement pour etre prise en compte.
# =====================================================================

# --- Supabase (cote navigateur) ---
# Uniquement des cles PUBLIQUES ici (inlinees dans le bundle client).
# Ne JAMAIS mettre la cle service_role cote frontend.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>

# --- API FastAPI ---
# Base URL de l'API Python (backend Railway en production). Sans slash final.
# NB : le nom exact attendu par le code est NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=https://<votre-backend>.up.railway.app
