# =====================================================================
# Backend (FastAPI) — variables d'environnement
# Copiez ce fichier vers .env en local ; en production (Railway), renseignez
# ces memes cles dans le dashboard du service. .env est ignore par git.
# Les noms doivent correspondre EXACTEMENT a app/core/config.py.
# =====================================================================

# --- Application ---
APP_NAME=To-Do-So API
ENVIRONMENT=production
DEBUG=false

# --- Supabase ---
# URL du projet (Supabase > Project Settings > API).
SUPABASE_URL=https://<ref>.supabase.co

# Cle service_role : acces serveur a PostgreSQL (bypass RLS). SECRET ABSOLU.
# Ne JAMAIS l'exposer cote frontend.
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Secret de signature JWT (Supabase > Project Settings > API > JWT Secret).
# Chemin LEGACY (HS256) ; les tokens utilisateurs ES256 sont verifies via le JWKS.
SUPABASE_JWT_SECRET=<jwt_secret>

# Audience attendue dans les JWT Supabase (valeur par defaut de Supabase Auth).
JWT_AUDIENCE=authenticated

# --- CORS ---
# URL du frontend autorisee a appeler l'API (domaine Vercel en production).
# Plusieurs origines possibles, separees par des virgules.
FRONTEND_URL=https://<votre-app>.vercel.app
